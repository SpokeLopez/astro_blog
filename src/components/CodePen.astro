---
interface Props {
  id: string;
  title?: string;
  user?: string;
  height?: number;
  defaultTab?: 'html' | 'css' | 'js' | 'result' | 'html,result' | 'css,result' | 'js,result';
  theme?: 'dark' | 'light';
}

const { 
  id, 
  title = 'CodePen Demo',
  user = 'codepen',
  height = 400,
  defaultTab = 'result',
  theme = 'dark'
} = Astro.props;

const penUrl = `https://codepen.io/${user}/pen/${id}`;
const embedUrl = `https://codepen.io/${user}/embed/${id}?default-tab=${defaultTab}&theme-id=${theme}`;
---

<div class="codepen-wrapper">
  <div class="codepen-header">
    <span class="codepen-label">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M24 8.182l-.018-.087-.017-.05c-.01-.024-.018-.05-.03-.075-.003-.018-.015-.034-.02-.05l-.035-.067-.03-.05-.044-.06-.046-.045-.06-.06-.054-.05-.07-.04-.084-.07-.028-.015-.065-.03-.075-.032-.09-.026-.083-.02-.093-.018-.092-.011-.095-.007-.063 0-11.444 7.6-11.444-7.6-.063 0-.095.007-.093.011-.093.018-.083.02-.09.026-.075.032-.065.03-.028.015-.084.07-.07.04-.054.05-.06.06-.046.045-.044.06-.03.05-.035.067-.02.05-.03.075-.017.05-.018.087-.004.094v7.636l.004.094.018.087.017.05c.01.024.018.05.03.075.003.018.015.034.02.05l.035.067.03.05.044.06.046.045.06.06.054.05.07.04.084.07.028.015.065.03.075.032.09.026.083.02.093.018.093.011.095.007.063 0 11.444-7.6 11.444 7.6.063 0 .095-.007.093-.011.093-.018.083-.02.09-.026.075-.032.065-.03.028-.015.084-.07.07-.04.054-.05.06-.06.046-.045.044-.06.03-.05.035-.067.02-.05c.01-.024.02-.05.03-.075l.017-.05.018-.087.004-.094v-7.636l-.004-.094zm-12.92 8.06l-4.71-3.14 4.71-3.135v6.275zm1.84 0v-6.275l4.71 3.135-4.71 3.14zm-1.84-7.76l-3.89 2.593-3.47-2.312 7.36-4.89v4.609zm1.84-4.609l7.36 4.89-3.47 2.312-3.89-2.593v-4.609zm-8.8 9.372l-2.27-1.512v-3.025l2.27 1.51v3.027zm1.92-4.537l3.47-2.312 3.47 2.312-3.47 2.312-3.47-2.312zm7.77 4.537v-3.027l2.27-1.51v3.025l-2.27 1.512z"/>
      </svg>
      <span>CodePen</span>
    </span>
    <a href={penUrl} target="_blank" rel="noopener noreferrer" class="codepen-link">
      Abrir en CodePen
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
        <polyline points="15 3 21 3 21 9"></polyline>
        <line x1="10" y1="14" x2="21" y2="3"></line>
      </svg>
    </a>
  </div>
  <iframe 
    height={height}
    style={`width: 100%;`}
    scrolling="no" 
    title={title}
    src={embedUrl}
    frameborder="no" 
    loading="lazy" 
    allowtransparency="true" 
    allowfullscreen="true"
  >
    Ver el Pen <a href={penUrl}>{title}</a> en <a href="https://codepen.io">CodePen</a>.
  </iframe>
</div>

<style>
  .codepen-wrapper {
    margin: var(--space-xl) 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-bg-code);
  }

  .codepen-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
  }

  .codepen-label {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .codepen-link {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .codepen-link:hover {
    color: var(--color-accent);
  }

  iframe {
    display: block;
    background-color: #1e1e22;
  }
</style>
