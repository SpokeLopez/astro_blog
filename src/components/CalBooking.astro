---
const CAL_PROFILE_URL = 'https://cal.com/eduardo-lopez-nmf4id';

interface Props {
  variant?: 'sidebar' | 'compact';
}

const { variant = 'sidebar' } = Astro.props;
---

<aside
  class:list={['cal-booking', variant === 'compact' && 'cal-booking--compact']}
  aria-label="Agendar reunión con Eduardo López"
>
  <div class="cal-booking__inner">
    <span class="cal-booking__badge">Agenda abierta</span>
    <p class="cal-booking__brand">¿Hablamos?</p>
    {variant === 'sidebar' && (
      <p class="cal-booking__text">
        Cuéntame sobre tu proyecto o si buscas colaborar conmigo.
      </p>
    )}
    {variant === 'compact' && (
      <p class="cal-booking__text cal-booking__text--short">
        Reserva 15 o 30 min conmigo
      </p>
    )}
    <ul class="cal-booking__durations" role="list">
      <li>15 min</li>
      <li>30 min</li>
    </ul>
    <a
      href={CAL_PROFILE_URL}
      class="cal-booking__cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      Elegir horario
    </a>
    <p class="cal-booking__hint">Videollamada</p>
  </div>
</aside>

<style>
  .cal-booking {
    --cal-brand: #111827;
    --cal-brand-hover: #1f2937;
  }

  [data-theme='light'] .cal-booking {
    --cal-brand: #0f172a;
    --cal-brand-hover: #334155;
  }

  .cal-booking__inner {
    padding: var(--space-lg);
    background: linear-gradient(
      145deg,
      var(--color-bg-card) 0%,
      color-mix(in srgb, var(--color-accent) 6%, var(--color-bg-card)) 100%
    );
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
  }

  [data-theme='light'] .cal-booking__inner {
    box-shadow: 0 4px 20px rgba(15, 118, 110, 0.08);
  }

  .cal-booking__badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: var(--color-accent-muted);
    padding: 0.2em 0.55em;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-sm);
  }

  .cal-booking__brand {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.02em;
  }

  .cal-booking__text {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .cal-booking__text--short {
    margin-bottom: var(--space-xs);
  }

  .cal-booking__durations {
    display: flex;
    gap: var(--space-sm);
    list-style: none;
    margin: 0 0 var(--space-md);
    padding: 0;
  }

  .cal-booking__durations li {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 0.2em 0.6em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
  }

  .cal-booking__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    width: 100%;
    padding: 0.65em 1em;
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff !important;
    text-decoration: none !important;
    background: var(--cal-brand);
    border-radius: var(--radius-md);
    transition: background-color 0.2s ease, transform 0.15s ease;
  }

  .cal-booking__cta:hover {
    background: var(--cal-brand-hover);
    color: #fff !important;
    transform: translateY(-1px);
  }

  .cal-booking__hint {
    margin-top: var(--space-sm);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  .cal-booking--compact .cal-booking__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm) var(--space-md);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-xl);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .cal-booking--compact .cal-booking__badge,
  .cal-booking--compact .cal-booking__durations,
  .cal-booking--compact .cal-booking__hint {
    display: none;
  }

  .cal-booking--compact .cal-booking__brand {
    margin: 0;
    font-size: 0.9375rem;
    flex: 1 1 auto;
    min-width: 0;
  }

  .cal-booking--compact .cal-booking__cta {
    width: auto;
    flex-shrink: 0;
    padding: 0.5em 1rem;
  }
</style>
