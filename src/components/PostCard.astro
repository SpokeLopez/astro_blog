---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
  readingTime?: string;
}

const { title, description, date, slug, tags, readingTime = '3 min' } = Astro.props;

const formattedDate = date.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const tagColors: Record<string, string> = {
  css: 'tag-css',
  javascript: 'tag-js',
  js: 'tag-js',
  html: 'tag-html',
  react: 'tag-react',
  astro: 'tag-astro',
  tutorial: 'tag-tutorial',
  magento: 'tag-magento',
  ecommerce: 'tag-ecommerce',
};
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="post-link">
    <div class="post-meta">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="separator">·</span>
      <span class="reading-time">{readingTime} de lectura</span>
    </div>
    
    <h3 class="post-title">{title}</h3>
    <p class="post-description">{description}</p>
    
    <div class="post-tags">
      {tags.map(tag => (
        <span class:list={['tag', tagColors[tag.toLowerCase()] || 'tag-default']}>
          {tag}
        </span>
      ))}
    </div>
  </a>
</article>

<style>
  .post-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all 0.2s ease;
  }

  .post-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
  }

  .post-link {
    display: block;
    padding: var(--space-lg);
    color: inherit;
    text-decoration: none;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .separator {
    color: var(--color-border);
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .post-card:hover .post-title {
    color: var(--color-accent);
  }

  .post-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-md);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25em 0.75em;
    border-radius: var(--radius-sm);
    text-transform: lowercase;
  }

  .tag-css {
    background-color: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
  }

  .tag-js {
    background-color: rgba(234, 179, 8, 0.15);
    color: #facc15;
  }

  .tag-html {
    background-color: rgba(249, 115, 22, 0.15);
    color: #fb923c;
  }

  .tag-react {
    background-color: rgba(6, 182, 212, 0.15);
    color: #22d3ee;
  }

  .tag-astro {
    background-color: rgba(255, 93, 1, 0.15);
    color: #ff7e33;
  }

  .tag-tutorial {
    background-color: rgba(168, 85, 247, 0.15);
    color: #c084fc;
  }

  .tag-magento {
    background-color: rgba(235, 100, 52, 0.15);
    color: #f97316;
  }

  .tag-ecommerce {
    background-color: rgba(16, 185, 129, 0.15);
    color: #34d399;
  }

  .tag-default {
    background-color: var(--color-bg-secondary);
    color: var(--color-text-secondary);
  }
</style>
