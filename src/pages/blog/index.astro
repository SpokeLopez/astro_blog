---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import '../../styles/blog-listings.css';

const allPosts = await Astro.glob('./*.mdx');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

const allTags = [...new Set(sortedPosts.flatMap(post => post.frontmatter.tags))];
const PAGE_SIZE = 9;
---

<BaseLayout
  title="Blog | SpokeLopez"
  description="Tutoriales, notas técnicas y retos: CSS, JavaScript, Magento 2, AdventJS y buenas prácticas de desarrollo web."
>
  <div class="blog-listing">
    <header class="page-header">
      <span class="page-tag">Blog</span>
      <h1>Artículos y tutoriales</h1>
      <p class="page-description">
        Contenido práctico sobre frontend, backend, e-commerce y retos de código.
      </p>
    </header>

    <div class="blog-filters">
      <p class="filter-intro">Pulsa una etiqueta para filtrar; un segundo clic en la misma la quita.</p>
      <div class="tags-list">
        <span class="filter-label">Tema</span>
        {allTags.map(tag => (
          <button type="button" class="filter-tag" data-tag={tag.toLowerCase()}>
            {tag}
          </button>
        ))}
      </div>
    </div>

    <div class="posts-grid">
      {sortedPosts.map((post, i) => (
        <PostCard
          title={post.frontmatter.title}
          description={post.frontmatter.description}
          date={new Date(post.frontmatter.date)}
          slug={post.file.split('/').pop()?.replace('.mdx', '') || ''}
          tags={post.frontmatter.tags}
          readingTime={post.frontmatter.readingTime}
          data-index={i}
        />
      ))}
    </div>

    {sortedPosts.length === 0 && (
      <div class="empty-state" role="status">
        <p>Aquí aún no hay publicaciones. En cuanto añada entradas nuevas, las verás en esta lista.</p>
      </div>
    )}

    <Pagination totalPosts={sortedPosts.length} pageSize={PAGE_SIZE} />
  </div>
</BaseLayout>

<script>
  const PAGE_SIZE = 9;
  let currentPage = 0;
  let activeTag = '';

  const filterTags = document.querySelectorAll<HTMLElement>('.filter-tag');
  const allCards = Array.from(document.querySelectorAll<HTMLElement>('.posts-grid .post-card'));
  const pagination = document.querySelector('.pagination');
  const prevBtn = document.querySelector<HTMLButtonElement>('.prev-btn');
  const nextBtn = document.querySelector<HTMLButtonElement>('.next-btn');
  const pageNums = document.querySelectorAll<HTMLButtonElement>('.page-num');

  function getVisible() {
    return activeTag
      ? allCards.filter(card =>
          Array.from(card.querySelectorAll('.tag'))
            .some(t => t.textContent?.toLowerCase().trim() === activeTag)
        )
      : allCards;
  }

  function render() {
    const visible = getVisible();
    const totalPages = Math.ceil(visible.length / PAGE_SIZE);
    currentPage = Math.min(currentPage, Math.max(0, totalPages - 1));

    allCards.forEach(c => (c.style.display = 'none'));
    visible.slice(currentPage * PAGE_SIZE, (currentPage + 1) * PAGE_SIZE)
           .forEach(c => (c.style.display = ''));

    // Pagination visibility
    if (pagination) {
      (pagination as HTMLElement).style.display = totalPages > 1 ? '' : 'none';
    }
    prevBtn && (prevBtn.disabled = currentPage === 0);
    nextBtn && (nextBtn.disabled = currentPage >= totalPages - 1);
    pageNums.forEach((btn, i) => {
      btn.classList.toggle('active', i === currentPage);
      btn.style.display = i < totalPages ? '' : 'none';
    });
  }

  filterTags.forEach(tag => {
    tag.addEventListener('click', () => {
      const isActive = tag.classList.contains('active');
      filterTags.forEach(t => t.classList.remove('active'));
      activeTag = isActive ? '' : (tag.dataset.tag ?? '');
      if (!isActive) tag.classList.add('active');
      currentPage = 0;
      render();
    });
  });

  prevBtn?.addEventListener('click', () => { currentPage--; render(); });
  nextBtn?.addEventListener('click', () => { currentPage++; render(); });
  pageNums.forEach(btn => {
    btn.addEventListener('click', () => { currentPage = Number(btn.dataset.page); render(); });
  });

  render();
</script>
