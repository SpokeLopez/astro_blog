  <!-- Experience Section -->
  <section class="experience-section">
    <div class="section-header">
      <span class="section-tag">Experiencia</span>
      <h2>Mi trayectoria profesional</h2>
      <p class="section-subtitle">+8 años de experiencia en desarrollo web y e-commerce</p>
    </div>
    
    <!-- Timeline Roadmap -->
    <div class="timeline-container">
      <div class="timeline-track"></div>
      <div class="timeline-wrapper">
        {experience.map((exp, index) => (
          <div class="timeline-item" data-index={index}>
            <span class="timeline-year-label">{exp.period.split(' - ')[0]}</span>
            <div class="timeline-dot">
              <span class="dot-inner"></span>
            </div>
            <details class="timeline-card">
              <summary class="timeline-summary">
                <h3 class="timeline-role">{exp.role}</h3>
                <span class="timeline-company">{exp.company}</span>
                <div class="timeline-skills">
                  {exp.skills.slice(0, 3).map((skill: string) => (
                    <span class="timeline-skill">{skill}</span>
                  ))}
                </div>
                <span class="timeline-expand-hint">Ver detalles</span>
              </summary>
              <div class="timeline-details">
                <p class="timeline-location">{exp.location}</p>
                <p class="timeline-description">{exp.description}</p>
                <div class="timeline-all-skills">
                  {exp.skills.map((skill: string) => (
                    <span class="timeline-skill">{skill}</span>
                  ))}
                </div>
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TikTok Videos Section -->
  <section class="tiktok-section">
    <div class="section-header">
      <span class="section-tag">TikTok</span>
      <h2>Últimos videos</h2>
      <a href="https://tiktok.com/@spokelopez" target="_blank" rel="noopener noreferrer" class="view-all">
        Ver todos
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
    <div class="tiktok-grid">
      {tiktokVideos.map(video => (
        <a href={`https://tiktok.com/@spokelopez/video/${video.id}`} target="_blank" rel="noopener noreferrer" class="tiktok-card">
          <div class="tiktok-thumbnail">
            <div class="tiktok-play">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
              </svg>
            </div>
          </div>
          <div class="tiktok-info">
            <h4>{video.title}</h4>
            <span class="tiktok-views">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
              {video.views}
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Posts Section -->
  <section class="latest-posts">
    <div class="section-header">
      <span class="section-tag">Blog</span>
      <h2>Últimos tutoriales</h2>
      <a href="/blog" class="view-all">
        Ver todos
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
    
    <div class="posts-grid">
      {sortedPosts.map(post => (
        <PostCard
          title={post.frontmatter.title}
          description={post.frontmatter.description}
          date={new Date(post.frontmatter.date)}
          slug={post.file.split('/').pop()?.replace('.mdx', '') || ''}
