const allPosts = await Astro.glob('./blog/*.mdx');
const homeBlogPosts = allPosts.filter((post) => post.frontmatter.category !== 'adventjs');
const sortedPosts = homeBlogPosts
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);

const CAL_PROFILE_URL = 'https://cal.com/eduardo-lopez-nmf4id';

const PLAYLIST_ID = 'PLVSc1l65FPFh_xUmQtgfaYSSEete1XPku';
const YT_KEY = import.meta.env.YOUTUBE_API_KEY;
let playlistVideos: { id: string; title: string; thumbnail: string }[] = [];
const MAX_YT_VIDEOS = 3;

try {
  if (YT_KEY) {
    const res = await fetch(
      `https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&maxResults=${MAX_YT_VIDEOS}&playlistId=${PLAYLIST_ID}&key=${YT_KEY}`
    );
    const data = await res.json();
    playlistVideos = (data.items ?? []).map((item: any) => ({
      id: item.snippet.resourceId.videoId,
      title: item.snippet.title,
      thumbnail: item.snippet.thumbnails?.medium?.url
        ?? `https://img.youtube.com/vi/${item.snippet.resourceId.videoId}/mqdefault.jpg`,
    }));
  }
} catch (_) {}

if (playlistVideos.length === 0) {
  try {
    const rssRes = await fetch(`https://www.youtube.com/feeds/videos.xml?playlist_id=${PLAYLIST_ID}`);
    const rss = await rssRes.text();
    const entries = rss.split('<entry>').slice(1, MAX_YT_VIDEOS + 1);

    playlistVideos = entries.map((entry) => {
      const idMatch = entry.match(/<yt:videoId>([^<]+)<\/yt:videoId>/);
      const titleMatch = entry.match(/<title>([^<]+)<\/title>/);
      const thumbMatch = entry.match(/media:thumbnail[^>]+url="([^"]+)"/);
      const id = idMatch?.[1] ?? '';

      return {
        id,
        title: titleMatch?.[1] ?? 'Video de YouTube',
        thumbnail: thumbMatch?.[1] ?? `https://img.youtube.com/vi/${id}/mqdefault.jpg`,
      };
    }).filter((video) => video.id);
  } catch (_) {}
}

