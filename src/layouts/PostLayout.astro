---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    tags: string[];
    tiktokUrl?: string;
  };
}

const { frontmatter } = Astro.props;

const formattedDate = new Date(frontmatter.date).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const tagColors: Record<string, string> = {
  css: 'tag-css',
  javascript: 'tag-js',
  js: 'tag-js',
  html: 'tag-html',
  react: 'tag-react',
  astro: 'tag-astro',
  tutorial: 'tag-tutorial',
  magento: 'tag-magento',
  ecommerce: 'tag-ecommerce',
  less: 'tag-less',
  shopify: 'tag-shopify',
  liquid: 'tag-liquid',
};
---

<BaseLayout title={`${frontmatter.title} | DevTips`} description={frontmatter.description}>
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={new Date(frontmatter.date).toISOString()}>{formattedDate}</time>
        {frontmatter.tiktokUrl && (
          <>
            <span class="separator">·</span>
            <a href={frontmatter.tiktokUrl} target="_blank" rel="noopener noreferrer" class="tiktok-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
              </svg>
              Ver en TikTok
            </a>
          </>
        )}
      </div>
      
      <h1 class="post-title">{frontmatter.title}</h1>
      
      <p class="post-description">{frontmatter.description}</p>
      
      <div class="post-tags">
        {frontmatter.tags.map(tag => (
          <span class:list={['tag', tagColors[tag.toLowerCase()] || 'tag-default']}>
            {tag}
          </span>
        ))}
      </div>
    </header>
    
    <div class="post-content">
      <slot />
    </div>
    
    <footer class="post-footer">
      <div class="share-section">
        <span class="share-label">Compartir</span>
        <div class="share-buttons">
          <a class="share-btn share-x" id="share-x" href="#" target="_blank" rel="noopener noreferrer" aria-label="Compartir en X">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a class="share-btn share-linkedin" id="share-linkedin" href="#" target="_blank" rel="noopener noreferrer" aria-label="Compartir en LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a class="share-btn share-whatsapp" id="share-whatsapp" href="#" target="_blank" rel="noopener noreferrer" aria-label="Compartir por WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
          </a>
          <button class="share-btn share-copy" id="share-copy" aria-label="Copiar enlace">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
        </div>
      </div>

      <a href="/blog" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Volver al blog
      </a>
    </footer>
  </article>
</BaseLayout>

<script>
  const url = encodeURIComponent(window.location.href);
  const title = encodeURIComponent(document.title);

  (document.getElementById('share-x') as HTMLAnchorElement).href =
    `https://x.com/intent/tweet?url=${url}&text=${title}`;

  (document.getElementById('share-linkedin') as HTMLAnchorElement).href =
    `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;

  (document.getElementById('share-whatsapp') as HTMLAnchorElement).href =
    `https://wa.me/?text=${title}%20${url}`;

  document.getElementById('share-copy')!.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    const btn = document.getElementById('share-copy')!;
    btn.classList.add('copied');
    setTimeout(() => btn.classList.remove('copied'), 2000);
  });
</script>

<style>
  .post {
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .separator {
    color: var(--color-border);
  }

  .tiktok-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .tiktok-link:hover {
    color: var(--color-accent);
  }

  .post-title {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-md);
    text-wrap: balance;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-lg);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25em 0.75em;
    border-radius: var(--radius-sm);
    text-transform: lowercase;
  }

  .tag-css { background-color: rgba(59, 130, 246, 0.15); color: #60a5fa; }
  .tag-js { background-color: rgba(234, 179, 8, 0.15); color: #facc15; }
  .tag-html { background-color: rgba(249, 115, 22, 0.15); color: #fb923c; }
  .tag-react { background-color: rgba(6, 182, 212, 0.15); color: #22d3ee; }
  .tag-astro { background-color: rgba(255, 93, 1, 0.15); color: #ff7e33; }
  .tag-tutorial { background-color: rgba(168, 85, 247, 0.15); color: #c084fc; }
  .tag-magento { background-color: rgba(235, 100, 52, 0.15); color: #f97316; }
  .tag-ecommerce { background-color: rgba(16, 185, 129, 0.15); color: #34d399; }
  .tag-less { background-color: rgba(45, 212, 191, 0.15); color: #5eead4; }
  .tag-shopify { background-color: rgba(34, 197, 94, 0.15); color: #86efac; }
  .tag-liquid { background-color: rgba(96, 165, 250, 0.15); color: #93c5fd; }
  .tag-default { background-color: var(--color-bg-secondary); color: var(--color-text-secondary); }

  .post-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-lg);
    color: var(--color-text-secondary);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
    color: var(--color-text-secondary);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-sm);
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-lg);
    margin: var(--space-xl) 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-2xl) 0;
  }

  .post-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .share-section {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .share-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .share-buttons {
    display: flex;
    gap: var(--space-sm);
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-card);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .share-btn:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
  }

  .share-btn.copied {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 1.75rem;
    }
  }
</style>
